# Jot — userData .env template (not for committing real secrets)
#
# The app reads this file from its Electron userData directory (e.g. after you set a key in-app),
# not from the repo root. NEVER commit .env with real keys.
#
# Implemented today: ANTHROPIC_API_KEY, PROACTIVE_RECALL_MODEL (see aiOrganize.js).
# Names starting with PROACTIVE_RECALL_ are legacy but still used for Jot’s optional AI model.
# Other PROACTIVE_RECALL_* keys below are not wired in app-main.js / appWatcher.js yet;
# tuning is currently via constants in those files.

# ── Anthropic API (required for AI assistant) ──────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ─────────────────────────────────────────────────────────
# Claude model for Organize / cleanup flows (default: claude-sonnet-4-6)
# PROACTIVE_RECALL_MODEL=claude-sonnet-4-6

# Buttonless Buddy chat model (default: claude-haiku-4-5 — faster, higher rate limits for bulk organizes)
# JOT_AI_MODEL=claude-haiku-4-5

# Enable/disable proactive surfacing (default: true)
# PROACTIVE_RECALL_SURFACING=true

# Polling interval in ms for frontmost app detection (default: 1500)
# PROACTIVE_RECALL_POLL_MS=1500

# Cooldown in minutes before the same note can be re-surfaced (default: 30)
# PROACTIVE_RECALL_COOLDOWN_MIN=30

# Overlay auto-dismiss time in ms (default: 10000)
# PROACTIVE_RECALL_DISMISS_MS=10000
