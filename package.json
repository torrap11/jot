{
  "name": "jot",
  "version": "2.2.0",
  "description": "Jot — local-first notes with screen recording, proactive resurfacing, and AI agent",
  "main": "app-main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/*.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "clean:dist": "rm -rf dist",
    "dist": "npm run dist:arm64",
    "dist:arm64": "npm run clean:dist && electron-builder --mac --arm64 --publish never",
    "dist:universal": "npm run clean:dist && electron-builder --mac --universal --publish never",
    "dist:signed": "npm run clean:dist && electron-builder --mac --universal --publish never --config.mac.identity=\"Developer ID Application\"",
    "dist:notarized": "npm run dist:signed",
    "preflight": "bash scripts/preflight-ship.sh",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.jot.app",
    "productName": "Jot",
    "files": [
      "app-main.js",
      "preload.js",
      "database.js",
      "appWatcher.js",
      "surfaceEngine.js",
      "recallWatcher.js",
      "noteAppScan.js",
      "knownApps.js",
      "remindWorkflowParser.js",
      "noteCleanup.js",
      "aiOrganize.js",
      "captureWorkflow.js",
      "overlayCommand.js",
      "timeParser.js",
      "resurfaceScheduler.js",
      "jot-ai/**/*",
      "integration/**/*",
      "renderer/**/*",
      "overlay/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../proactive-recall/target/release/screenpipe",
        "to": "screenpipe",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "identity": null,
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "Jot-${version}.${ext}",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Jot reads the frontmost application to surface relevant notes.",
        "NSScreenCaptureUsageDescription": "Jot records your laptop screen locally so you can search what you have seen. It does not use your microphone or camera.",
        "NSAutomationDescription": "Jot uses Automation to read the currently active app name for note surfacing."
      }
    },
    "dmg": {
      "title": "Install Jot",
      "artifactName": "Jot-${version}.${ext}",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 96,
      "contents": [
        { "x": 140, "y": 200, "type": "file" },
        { "x": 400, "y": 200, "type": "link", "path": "/Applications" }
      ]
    },
    "afterSign": "scripts/notarize.js"
  },
  "keywords": [
    "notes",
    "productivity",
    "electron",
    "macos"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "file-uri-to-path": "^1.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "@electron/rebuild": "^4.0.3",
    "electron": "^40.4.1",
    "electron-builder": "^26.0.12"
  }
}
